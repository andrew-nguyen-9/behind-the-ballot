---
import Layout from "../layouts/Layout.astro";
import { allRaces } from "../lib/races";
import { allChamberForecasts } from "../lib/forecast";

const raceCount = allRaces().length;
const senate = allChamberForecasts().find((c) => c.chamber === "Senate");

const sections = [
  { href: "/races", title: "Race tracker", body: "Every 2026 House, Senate, and Governor race — candidates, finance, polling, forecast." },
  { href: "/forecast", title: "Forecast", body: "Transparent heuristic + Monte Carlo model. Win probabilities, predicted margins, chamber control." },
  { href: "/members", title: "Members", body: "Profiles for members of Congress — party, district, ideology, voting record." },
  { href: "/gerrymander", title: "Maps & fairness", body: "District compactness and partisan-fairness metrics — several measures, with caveats." },
];
---

<Layout>
  <section class="py-6">
    <p class="eyebrow mb-4">The data beneath democracy</p>
    <h1 class="text-5xl tracking-tight text-balance">Behind the Ballot</h1>
    <p class="mt-4 max-w-prose font-serif text-xl text-balance text-[var(--color-muted)]">
      Non-partisan tracking and analytics for the 2026 U.S. midterms — and every election
      after. Every figure traces to a public <a href="/sources" class="text-[var(--color-brand)] underline underline-offset-2">source</a>.
    </p>
    <div class="mt-6 flex flex-wrap gap-3 text-sm">
      <a href="/races" class="rounded bg-[var(--color-brand)] px-4 py-2.5 font-semibold text-[var(--color-on-brand)]">
        Browse {raceCount} races
      </a>
      <a href="/forecast" class="rounded border border-[var(--color-border-strong)] px-4 py-2.5 font-semibold">
        See the forecast
      </a>
    </div>
    {senate && (
      <p class="mt-4 text-sm text-muted">
        Early fundamentals model (partisan lean only):{" "}
        {senate.dem_control_prob >= 0.5 ? "Democrats" : "Republicans"} favored for Senate control.
        See the <a href="/forecast" class="underline">forecast</a> and how it's built.
      </p>
    )}
  </section>

  <section class="mt-6 grid gap-4 sm:grid-cols-2" aria-label="Explore">
    {sections.map((s) => (
      <a
        href={s.href}
        class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-5 transition-colors hover:border-[var(--color-brand)]"
      >
        <h2 class="font-serif text-xl">{s.title}</h2>
        <p class="mt-1 text-sm text-[var(--color-muted)]">{s.body}</p>
      </a>
    ))}
  </section>
</Layout>
