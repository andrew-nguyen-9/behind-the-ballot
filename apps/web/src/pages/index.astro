---
import "../styles/global.css";
// Phase-0 placeholder. Real shell + nav land in v1.0.8-base-layout-seo.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Behind the Ballot</title>
    <meta
      name="description"
      content="Non-partisan 2026 midterm tracking & analytics."
    />
  </head>
  <body class="min-h-dvh font-sans antialiased">
    <main class="mx-auto max-w-2xl px-6 py-16">
      <h1 class="text-3xl font-bold">Behind the Ballot</h1>
      <p class="mt-3 text-balance text-muted">
        Non-partisan election tracking &amp; analytics.
      </p>

      <section class="mt-10" aria-label="Party color tokens">
        <h2 class="font-serif text-xl">Design tokens</h2>
        <ul class="mt-4 flex gap-3" role="list">
          <li class="flex items-center gap-2">
            <span class="size-5 rounded-sm bg-party-dem" aria-hidden="true"></span>Dem
          </li>
          <li class="flex items-center gap-2">
            <span class="size-5 rounded-sm bg-party-rep" aria-hidden="true"></span>Rep
          </li>
          <li class="flex items-center gap-2">
            <span class="size-5 rounded-sm bg-party-ind" aria-hidden="true"></span>Ind
          </li>
        </ul>
      </section>
    </main>
  </body>
</html>
