---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <h1 class="text-3xl font-bold">Behind the Ballot</h1>
  <p class="mt-3 max-w-prose text-balance text-muted">
    Non-partisan election tracking &amp; analytics for the 2026 midterms and every
    election after. Every figure traces to a public source.
  </p>

  <section class="mt-10" aria-label="Party color tokens">
    <h2 class="font-serif text-xl">Design tokens</h2>
    <ul class="mt-4 flex gap-4" role="list">
      <li class="flex items-center gap-2">
        <span class="size-5 rounded-sm bg-party-dem" aria-hidden="true"></span>Dem
      </li>
      <li class="flex items-center gap-2">
        <span class="size-5 rounded-sm bg-party-rep" aria-hidden="true"></span>Rep
      </li>
      <li class="flex items-center gap-2">
        <span class="size-5 rounded-sm bg-party-ind" aria-hidden="true"></span>Ind
      </li>
    </ul>
  </section>
</Layout>
