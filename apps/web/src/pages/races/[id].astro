---
import Layout from "../../layouts/Layout.astro";
import { allRaces, partyColorClass, partyLabel } from "../../lib/races";
import { financeForRace, fmtUSD } from "../../lib/finance";
import { pollingForRace } from "../../lib/polling";
import { forecastForRace, marginLabel } from "../../lib/forecast";
import type { RaceConfig } from "../../config/schema";

// One SSG page per race config [F4c]. Real finance/polling/forecast figures attach in
// v1.3.4 / v1.4.4 / v1.8.6 (consuming baked gold artifacts) — this is the core shell.
export function getStaticPaths() {
  return allRaces().map((race) => ({ params: { id: race.id }, props: { race } }));
}

const { race } = Astro.props as { race: RaceConfig };
const officeLabel = { senate: "U.S. Senate", house: "U.S. House", governor: "Governor" }[
  race.office
];
const seat =
  race.office === "house" ? `${race.state}-${String(race.district).padStart(2, "0")}` : race.state;

// Finance figures [G13a] — join candidates by FEC id; bars scale to the max receipts.
// ponytail: accessible CSS bars (0 JS) over a chart island for a 2-way money compare.
const finance = financeForRace(race.id);
const financeByFec = new Map((finance ?? []).map((f) => [f.candidate_id, f]));
const maxReceipts = Math.max(1, ...(finance ?? []).map((f) => f.receipts));
const coverage = finance?.[0]?.coverage_end_date ?? null;

// Polling average [H1a] — per-party weighted average; 0-JS bars on a 0–100 scale.
// ponytail: headline average now; a trend sparkline (needs snapshot history) is a later
// island. partyColorClass reused for the bar fill.
const polling = pollingForRace(race.id);

// Forecast [N4a] — heuristic+MC win prob + predicted margin + 80% range. Derived figure:
// methodology + provenance linked, not a raw source row [R14a].
const forecast = forecastForRace(race.id);
const demPct = forecast ? Math.round(forecast.win_prob * 100) : 0;
---

<Layout title={race.title} description={`${officeLabel} race — ${race.title}.`}>
  <nav class="text-sm text-muted"><a href="/races" class="hover:underline">Races</a> / {seat}</nav>
  <h1 class="mt-2 text-3xl font-bold">{race.title}</h1>
  <p class="mt-1 text-muted">
    {officeLabel} · {seat} · <span class="capitalize">{race.status}</span> · {race.cycle}
  </p>

  <section class="mt-8" aria-labelledby="cands">
    <h2 id="cands" class="font-serif text-xl">Candidates</h2>
    {race.candidates.length === 0 ? (
      <p class="mt-3 text-muted">Candidates to be confirmed.</p>
    ) : (
      <ul class="mt-4 space-y-3" role="list">
        {race.candidates.map((c) => (
          <li class="flex items-center gap-3">
            <span
              class={`inline-block size-4 rounded-sm ${partyColorClass(c.party)}`}
              aria-hidden="true"
            ></span>
            <span class="font-medium">{c.name}</span>
            <span class="text-sm text-muted">{partyLabel(c.party)}</span>
            {c.incumbent && (
              <span class="rounded bg-surface px-2 py-0.5 text-xs text-muted">Incumbent</span>
            )}
          </li>
        ))}
      </ul>
    )}
  </section>

  {finance && finance.length > 0 && (
    <section class="mt-10" aria-labelledby="finance">
      <h2 id="finance" class="font-serif text-xl">Campaign finance</h2>
      <p class="mt-1 text-sm text-muted">
        Total receipts{coverage ? ` through ${coverage}` : ""}. Source:
        <a href="/sources" class="underline">FEC</a> (public domain).
      </p>
      <ul class="mt-4 space-y-3" role="list">
        {race.candidates.map((c) => {
          const f = c.fecCandidateId ? financeByFec.get(c.fecCandidateId) : undefined;
          if (!f) return null;
          const pct = Math.round((f.receipts / maxReceipts) * 100);
          return (
            <li>
              <div class="flex justify-between text-sm">
                <span class="font-medium">{c.name}</span>
                <span class="tabular-nums text-muted">
                  {fmtUSD(f.receipts)} raised · {fmtUSD(f.cash_on_hand)} cash
                </span>
              </div>
              <div
                class="mt-1 h-2 rounded-sm bg-surface"
                role="img"
                aria-label={`${c.name}: ${fmtUSD(f.receipts)} raised`}
              >
                <div class={`h-2 rounded-sm ${partyColorClass(c.party)}`} style={`width:${pct}%`}></div>
              </div>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {polling && polling.averages.length > 0 && (
    <section class="mt-10" aria-labelledby="polling">
      <h2 id="polling" class="font-serif text-xl">Polling average</h2>
      <p class="mt-1 text-sm text-muted">
        Weighted average as of {polling.as_of} ({polling.averages[0].n_polls} polls). Source:
        <a href="/sources" class="underline">538</a>.
      </p>
      <ul class="mt-4 space-y-3" role="list">
        {polling.averages.map((a) => (
          <li>
            <div class="flex justify-between text-sm">
              <span class="font-medium">{partyLabel(a.party)}</span>
              <span class="tabular-nums text-muted">{a.avg_pct.toFixed(1)}%</span>
            </div>
            <div
              class="mt-1 h-2 rounded-sm bg-surface"
              role="img"
              aria-label={`${partyLabel(a.party)}: ${a.avg_pct.toFixed(1)} percent`}
            >
              <div
                class={`h-2 rounded-sm ${partyColorClass(a.party)}`}
                style={`width:${Math.min(100, a.avg_pct)}%`}
              ></div>
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

  {forecast && (
    <section class="mt-10" aria-labelledby="forecast">
      <h2 id="forecast" class="font-serif text-xl">Forecast</h2>
      <p class="mt-1 text-sm text-muted">
        As of {forecast.as_of}. Heuristic + Monte Carlo —
        <a href="/forecast" class="underline">methodology</a>.
      </p>
      <div class="mt-3 flex flex-wrap gap-x-8 gap-y-2">
        <div>
          <div class="text-2xl font-bold tabular-nums">{demPct}%</div>
          <div class="text-sm text-muted">Democratic win probability</div>
        </div>
        <div>
          <div class="text-2xl font-bold tabular-nums">{marginLabel(forecast.margin)}</div>
          <div class="text-sm text-muted">
            predicted margin (range {marginLabel(forecast.margin_lo)} to{" "}
            {marginLabel(forecast.margin_hi)})
          </div>
        </div>
      </div>
    </section>
  )}
</Layout>
