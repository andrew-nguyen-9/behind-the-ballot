---
import Layout from "../../layouts/Layout.astro";
import { allRaces, partyColorClass, partyLabel } from "../../lib/races";
import type { RaceConfig } from "../../config/schema";

// One SSG page per race config [F4c]. Real finance/polling/forecast figures attach in
// v1.3.4 / v1.4.4 / v1.8.6 (consuming baked gold artifacts) — this is the core shell.
export function getStaticPaths() {
  return allRaces().map((race) => ({ params: { id: race.id }, props: { race } }));
}

const { race } = Astro.props as { race: RaceConfig };
const officeLabel = { senate: "U.S. Senate", house: "U.S. House", governor: "Governor" }[
  race.office
];
const seat =
  race.office === "house" ? `${race.state}-${String(race.district).padStart(2, "0")}` : race.state;
---

<Layout title={race.title} description={`${officeLabel} race — ${race.title}.`}>
  <nav class="text-sm text-muted"><a href="/races" class="hover:underline">Races</a> / {seat}</nav>
  <h1 class="mt-2 text-3xl font-bold">{race.title}</h1>
  <p class="mt-1 text-muted">
    {officeLabel} · {seat} · <span class="capitalize">{race.status}</span> · {race.cycle}
  </p>

  <section class="mt-8" aria-labelledby="cands">
    <h2 id="cands" class="font-serif text-xl">Candidates</h2>
    {race.candidates.length === 0 ? (
      <p class="mt-3 text-muted">Candidates to be confirmed.</p>
    ) : (
      <ul class="mt-4 space-y-3" role="list">
        {race.candidates.map((c) => (
          <li class="flex items-center gap-3">
            <span
              class={`inline-block size-4 rounded-sm ${partyColorClass(c.party)}`}
              aria-hidden="true"
            ></span>
            <span class="font-medium">{c.name}</span>
            <span class="text-sm text-muted">{partyLabel(c.party)}</span>
            {c.incumbent && (
              <span class="rounded bg-surface px-2 py-0.5 text-xs text-muted">Incumbent</span>
            )}
          </li>
        ))}
      </ul>
    )}
  </section>

  <p class="mt-10 text-sm text-muted">
    Finance, polling, and forecast figures attach as their data lands — each will trace to a
    <a href="/sources" class="underline">source</a>.
  </p>
</Layout>
