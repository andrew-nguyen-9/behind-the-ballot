---
import Layout from "../layouts/Layout.astro";
import { allMembers } from "../lib/members";
import { partyColorClass, partyLabel } from "../lib/races";

const members = allMembers();
const chambers: { key: "sen" | "rep"; label: string }[] = [
  { key: "sen", label: "U.S. Senate" },
  { key: "rep", label: "U.S. House" },
];
const seat = (m: (typeof members)[number]) =>
  m.chamber === "rep" ? `${m.state}-${String(m.district).padStart(2, "0")}` : m.state;
---

<Layout title="Members" description="Profiles for members of Congress.">
  <h1 class="text-3xl font-bold">Members</h1>
  <p class="mt-2 text-muted">{members.length} member{members.length === 1 ? "" : "s"} tracked.</p>

  {chambers.map(({ key, label }) => {
    const group = members.filter((m) => m.chamber === key);
    if (group.length === 0) return null;
    return (
      <section class="mt-8" aria-labelledby={key}>
        <h2 id={key} class="font-serif text-xl">{label}</h2>
        <ul class="mt-3 divide-y divide-[var(--color-border)]" role="list">
          {group.map((m) => (
            <li>
              <a href={`/members/${m.bioguide_id}`} class="flex items-center gap-3 py-3 hover:text-[var(--color-accent)]">
                <span class={`inline-block size-3 rounded-sm ${partyColorClass(m.party)}`} aria-hidden="true"></span>
                <span class="flex-1 font-medium">{m.name}</span>
                <span class="text-sm text-muted">{partyLabel(m.party)} · {seat(m)}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    );
  })}
</Layout>
