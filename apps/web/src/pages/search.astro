---
import Layout from "../layouts/Layout.astro";

// Pagefind static search [L891] (ADR 0006): a build-time index over the site, served from
// the CDN with no backend. The Pagefind UI is the one interactive island here; assets
// under /pagefind/* are generated by `pagefind --site dist` after the Astro build.
---

<Layout title="Search" description="Search races, members, districts, and articles.">
  <div data-pagefind-ignore>
    <h1 class="text-3xl font-bold">Search</h1>
    <p class="mt-2 text-muted">Search races, members, districts, and articles.</p>

    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <div id="search" class="mt-6"></div>

    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <script is:inline>
      window.addEventListener("DOMContentLoaded", () => {
        // PagefindUI is defined by the generated script above.
        if (window.PagefindUI) new window.PagefindUI({ element: "#search", showSubResults: true });
      });
    </script>
  </div>
</Layout>
