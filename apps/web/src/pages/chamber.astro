---
import Layout from "../layouts/Layout.astro";
import { chamberComposition, CLASS_II_2026_STATES } from "../lib/members";
import { partyColorClass, partyLabel } from "../lib/races";

const composition = chamberComposition();
const class2 = [...CLASS_II_2026_STATES].sort();
---

<Layout
  title="Chamber composition"
  description="Party breakdown of the U.S. House and Senate, plus the Senate seats up for election in 2026."
>
  <h1 class="text-3xl font-bold">Chamber composition</h1>
  <p class="mt-2 text-muted">
    Party breakdown per chamber, computed from the tracked member roster. Counts grow as live
    data lands; figures here reflect the current roster.
  </p>

  {composition.map((c) => (
    <section class="mt-8" aria-labelledby={c.chamber}>
      <h2 id={c.chamber} class="font-serif text-xl">{c.label}</h2>
      <p class="mt-1 text-sm text-muted">{c.total} seat{c.total === 1 ? "" : "s"} tracked</p>
      {c.total > 0 && (
        <>
          <div class="mt-3 flex h-4 w-full overflow-hidden rounded-sm" role="img"
            aria-label={c.byParty.map((p) => `${p.count} ${partyLabel(p.party)}`).join(", ")}>
            {c.byParty.map((p) => (
              <span class={partyColorClass(p.party)} style={`width:${(p.count / c.total) * 100}%`}></span>
            ))}
          </div>
          <ul class="mt-3 flex flex-wrap gap-x-6 gap-y-1 text-sm" role="list">
            {c.byParty.map((p) => (
              <li class="flex items-center gap-2">
                <span class={`inline-block size-3 rounded-sm ${partyColorClass(p.party)}`} aria-hidden="true"></span>
                <span class="font-medium">{partyLabel(p.party)}</span>
                <span class="text-muted">{p.count}</span>
              </li>
            ))}
          </ul>
        </>
      )}
    </section>
  ))}

  <section class="mt-10" aria-labelledby="class2">
    <h2 id="class2" class="font-serif text-xl">Senate seats up in 2026 (Class II)</h2>
    <p class="mt-1 text-sm text-muted">
      Senate seats are elected for six-year terms staggered into three classes. The 33 Class II
      seats below are on the ballot in 2026.
    </p>
    <ul class="mt-3 flex flex-wrap gap-2" role="list">
      {class2.map((st) => (
        <li class="rounded-sm border border-[var(--color-border)] px-2 py-1 text-sm font-medium">{st}</li>
      ))}
    </ul>
  </section>
</Layout>
